            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/submit_indicator.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "indicator": {
                    "data_type": "string",
                    "description": "情报指标",
                    "required": true,
                    "order": 0
                },
                "indicator_type": {
                    "data_type": "string",
                    "description": "指标类型",
                    "required": false,
                    "order": 1,
                    "default_value": "ip"
                },
                "severity": {
                    "data_type": "string",
                    "description": "风险等级",
                    "required": false,
                    "order": 2,
