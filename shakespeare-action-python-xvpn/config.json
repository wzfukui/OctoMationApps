{
    "name": "xvpn",
    "description": "离线模拟 VPN 远程接入系统，支持登录状态、账号创建、账号禁用和踢人下线",
    "app_version": "1.0.0",
    "jar": "xvpn.py",
    "readme": "resources/readme.md",
    "logo": "resources/xvpn_logo.svg",
    "category": "网络设备",
    "product_name": "XVPN 远程接入",
    "app_supplier": "雾帜智能",
    "logic_language": "PYTHON",
    "min_shakespeare_version": "1.0",
    "logic_language_version": "3",
    "has_test": true,
    "test_action": "health_check",
    "resources": "",
    "configuration": {
        "database_path": {
            "data_type": "string",
            "description": "SQLite 模拟状态库路径",
            "default_value": "/tmp/xvpn.db",
            "required": false,
            "order": 0
        },
        "scenario_profile": {
            "data_type": "string",
            "description": "模拟场景名称",
            "default_value": "default",
            "required": false,
            "order": 1
        },
        "scenario_seed": {
            "data_type": "string",
            "description": "模拟数据种子，可用于固定演示场景",
            "default_value": "x-series-default",
            "required": false,
            "order": 2
        },
        "delay_min_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最小模拟延迟秒数",
            "default_value": 1,
            "required": false,
            "order": 3
        },
        "delay_max_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最大模拟延迟秒数",
            "default_value": 3,
            "required": false,
            "order": 4
        }
    },
    "actions": [
        {
            "order": 0,
            "action": "health_check",
            "class_name": "health_check",
            "description": "健康检查",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/health_check.art",
            "safe_mode": false,
            "is_test": true,
            "classify": "query",
            "parameters": {},
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.msg",
                    "data_type": "string",
                    "description": "健康检查信息"
                },
                {
                    "data_path": "action_result.data.system_info",
                    "data_type": "jsonobject",
                    "description": "系统信息"
                }
            ]
        },
        {
            "order": 1,
            "action": "query_login_status",
            "class_name": "query_login_status",
            "description": "查询 VPN 用户登录状态",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_login_status.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "用户名",
                    "required": false,
                    "order": 0
                },
                "status": {
                    "data_type": "string",
                    "description": "状态",
                    "required": false,
                    "order": 1
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 2,
            "action": "query_online_users",
            "class_name": "query_online_users",
            "description": "查询 VPN 在线用户",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_online_users.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "用户名",
                    "required": false,
                    "order": 0
                },
                "status": {
                    "data_type": "string",
                    "description": "登录状态",
                    "required": false,
                    "order": 1,
                    "default_value": "online"
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回数量",
                    "required": false,
                    "order": 2,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 3,
            "action": "create_vpn_account",
            "class_name": "create_vpn_account",
            "description": "创建 VPN 账号",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/create_vpn_account.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "用户名",
                    "required": true,
                    "order": 0
                },
                "display_name": {
                    "data_type": "string",
                    "description": "显示名",
                    "required": false,
                    "order": 1,
                    "default_value": ""
                },
                "department": {
                    "data_type": "string",
                    "description": "部门",
                    "required": false,
                    "order": 2,
                    "default_value": "未分配"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 4,
            "action": "disable_vpn_account",
            "class_name": "disable_vpn_account",
            "description": "禁用 VPN 账号",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/disable_vpn_account.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "用户名",
                    "required": true,
                    "order": 0
                },
                "reason": {
                    "data_type": "string",
                    "description": "禁用原因",
                    "required": false,
                    "order": 1,
                    "default_value": "安全事件处置"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 5,
            "action": "enable_vpn_account",
            "class_name": "enable_vpn_account",
            "description": "启用 VPN 账号",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/enable_vpn_account.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "用户名",
                    "required": true,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 6,
            "action": "kick_vpn_user",
            "class_name": "kick_vpn_user",
            "description": "踢 VPN 用户下线",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/kick_vpn_user.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "用户名",
                    "required": true,
                    "order": 0
                },
                "reason": {
                    "data_type": "string",
                    "description": "踢下线原因",
                    "required": false,
                    "order": 1,
                    "default_value": "安全处置"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 7,
            "action": "query_vpn_history",
            "class_name": "query_vpn_history",
            "description": "查询 VPN 登录历史",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_vpn_history.art",
