{
    "name": "tencent_tianmu_sim",
    "description": "离线模拟腾讯天幕旁路阻断、解封、策略查询、TTL 到期和审计能力",
    "app_version": "1.0.0",
    "jar": "tencent_tianmu_sim.py",
    "readme": "resources/readme.md",
    "logo": "resources/tencent_tianmu_sim_logo.svg",
    "category": "安全产品",
    "product_name": "腾讯天幕 NIPS（模拟）",
    "app_supplier": "雾帜智能",
    "logic_language": "PYTHON",
    "min_shakespeare_version": "1.0",
    "logic_language_version": "3",
    "has_test": true,
    "test_action": "health_check",
    "resources": "",
    "configuration": {
        "database_path": {
            "data_type": "string",
            "description": "SQLite 模拟状态库路径",
            "default_value": "/tmp/tencent_tianmu_sim.db",
            "required": false,
            "order": 0
        },
        "scenario_profile": {
            "data_type": "string",
            "description": "模拟场景名称",
            "default_value": "default",
            "required": false,
            "order": 1
        },
        "delay_min_seconds": {
            "data_type": "integer",
            "description": "写动作最小模拟延迟秒数",
            "default_value": 1,
            "required": false,
            "order": 2
        },
        "delay_max_seconds": {
            "data_type": "integer",
            "description": "写动作最大模拟延迟秒数",
            "default_value": 3,
            "required": false,
            "order": 3
        },
        "simulated_api_status": {
            "data_type": "string",
            "description": "模拟 API 状态：healthy、degraded、unavailable",
            "default_value": "healthy",
            "required": false,
            "order": 4
        },
        "simulated_auth_status": {
            "data_type": "string",
            "description": "模拟鉴权状态：authorized、forbidden",
            "default_value": "authorized",
            "required": false,
            "order": 5
        },
        "simulated_link_status": {
            "data_type": "string",
            "description": "模拟链路状态：healthy、delayed、down",
            "default_value": "healthy",
            "required": false,
            "order": 6
        }
    },
    "actions": [
        {
            "order": 0,
            "action": "health_check",
            "class_name": "health_check",
            "description": "检查模拟 API、鉴权和组件状态",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/health_check.art",
            "safe_mode": false,
            "is_test": true,
            "classify": "query",
            "parameters": {},
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.system_info",
                    "data_type": "jsonobject",
                    "description": "产品和链路健康状态"
                }
            ]
        },
        {
            "order": 1,
            "action": "list_block_policies",
            "class_name": "list_block_policies",
            "description": "查询旁路阻断策略",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/list_block_policies.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "policy_id": {
                    "data_type": "string",
                    "description": "策略 ID",
                    "required": false,
                    "order": 0
                },
                "ip": {
                    "data_type": "string",
                    "description": "封禁 IP",
                    "required": false,
                    "order": 1
                },
                "status": {
                    "data_type": "string",
                    "description": "策略状态",
                    "required": false,
                    "order": 2
                },
                "trace_id": {
                    "data_type": "string",
                    "description": "SOAR trace_id",
                    "required": false,
                    "order": 3
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回数量",
                    "required": false,
                    "order": 4,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "记录列表"
                },
                {
                    "data_path": "action_result.data.record",
                    "data_type": "jsonobject",
                    "description": "首条记录"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "审计操作信息"
                }
            ]
        },
        {
            "order": 2,
            "action": "block_ip",
            "class_name": "block_ip",
            "description": "创建天幕旁路 IP 阻断策略",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/block_ip.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "ip": {
                    "data_type": "string",
                    "description": "需要封禁的 IP",
                    "required": true,
                    "order": 0
                },
                "reason": {
                    "data_type": "string",
                    "description": "封禁原因",
                    "required": false,
                    "order": 1,
                    "default_value": "SOAR 高危告警联动"
                },
                "ttl_minutes": {
                    "data_type": "integer",
                    "description": "封禁时长（分钟），0 表示永久",
                    "required": false,
                    "order": 2,
                    "default_value": 60
                },
                "scope": {
                    "data_type": "string",
                    "description": "阻断范围",
                    "required": false,
                    "order": 3,
                    "default_value": "global"
                },
                "direction": {
                    "data_type": "string",
                    "description": "阻断方向",
                    "required": false,
                    "order": 4,
                    "default_value": "bidirectional"
                },
                "alert_id": {
                    "data_type": "string",
                    "description": "关联 SOC 告警 ID",
                    "required": false,
                    "order": 5
                },
                "trace_id": {
                    "data_type": "string",
                    "description": "SOAR 链路追踪 ID",
                    "required": false,
                    "order": 10,
                    "default_value": "demo-trace-web-0001"
                },
                "operator": {
                    "data_type": "string",
                    "description": "操作者账号",
                    "required": false,
                    "order": 11,
                    "default_value": "soar-demo"
                },
                "trigger_source": {
                    "data_type": "string",
                    "description": "触发来源，例如 soc_alert、manual、scheduled",
                    "required": false,
                    "order": 12,
                    "default_value": "soc_alert"
                },
                "approval_id": {
                    "data_type": "string",
                    "description": "审批单 ID；需要审批时由剧本传入",
                    "required": false,
                    "order": 13
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.policy_id",
                    "data_type": "string",
                    "description": "策略 ID"
                },
                {
                    "data_path": "action_result.data.policy",
                    "data_type": "jsonobject",
                    "description": "策略详情"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "审计操作信息"
                }
            ]
        },
        {
            "order": 3,
            "action": "unblock_ip",
            "class_name": "unblock_ip",
            "description": "解除天幕旁路 IP 阻断",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/unblock_ip.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "policy_id": {
                    "data_type": "string",
                    "description": "策略 ID；与目标至少填写一项",
                    "required": false,
                    "order": 0
                },
                "ip": {
                    "data_type": "string",
                    "description": "需要解封的 IP；与策略 ID 至少填写一项",
                    "required": false,
                    "order": 1
                },
                "reason": {
                    "data_type": "string",
                    "description": "解封原因",
                    "required": false,
                    "order": 2,
                    "default_value": "TTL 到期或人工复核"
                },
                "trace_id": {
                    "data_type": "string",
                    "description": "SOAR 链路追踪 ID",
                    "required": false,
                    "order": 10,
                    "default_value": "demo-trace-web-0001"
                },
                "operator": {
                    "data_type": "string",
                    "description": "操作者账号",
                    "required": false,
                    "order": 11,
                    "default_value": "soar-demo"
                },
                "trigger_source": {
                    "data_type": "string",
                    "description": "触发来源，例如 soc_alert、manual、scheduled",
                    "required": false,
                    "order": 12,
                    "default_value": "soc_alert"
                },
                "approval_id": {
                    "data_type": "string",
                    "description": "审批单 ID；需要审批时由剧本传入",
                    "required": false,
                    "order": 13
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.policy_id",
                    "data_type": "string",
                    "description": "策略 ID"
                },
                {
                    "data_path": "action_result.data.policy",
                    "data_type": "jsonobject",
                    "description": "策略详情"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "审计操作信息"
                }
            ]
        },
        {
            "order": 4,
            "action": "expire_due_policies",
            "class_name": "expire_due_policies",
            "description": "扫描并自动释放已到期策略",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/expire_due_policies.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "as_of": {
                    "data_type": "string",
                    "description": "到期判断时间，ISO 8601；默认当前时间",
                    "required": false,
                    "order": 0
                },
                "trace_id": {
                    "data_type": "string",
                    "description": "SOAR 链路追踪 ID",
                    "required": false,
                    "order": 10,
                    "default_value": "demo-trace-web-0001"
                },
                "operator": {
                    "data_type": "string",
                    "description": "操作者账号",
                    "required": false,
                    "order": 11,
                    "default_value": "soar-demo"
                },
                "trigger_source": {
                    "data_type": "string",
                    "description": "触发来源，例如 soc_alert、manual、scheduled",
                    "required": false,
                    "order": 12,
                    "default_value": "soc_alert"
                },
                "approval_id": {
                    "data_type": "string",
                    "description": "审批单 ID；需要审批时由剧本传入",
                    "required": false,
                    "order": 13
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.policy_id",
                    "data_type": "string",
                    "description": "策略 ID"
                },
                {
                    "data_path": "action_result.data.policy",
                    "data_type": "jsonobject",
                    "description": "策略详情"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "审计操作信息"
                }
            ]
        },
        {
            "order": 5,
            "action": "query_operation_history",
            "class_name": "query_operation_history",
            "description": "查询产品模拟操作审计记录",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_operation_history.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "trace_id": {
                    "data_type": "string",
                    "description": "按 trace_id 过滤",
                    "required": false,
                    "order": 0
                },
                "target": {
                    "data_type": "string",
                    "description": "按目标 IP、资产或策略 ID 过滤",
                    "required": false,
                    "order": 1
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回数量",
                    "required": false,
                    "order": 2,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "记录列表"
                },
                {
                    "data_path": "action_result.data.record",
                    "data_type": "jsonobject",
                    "description": "首条记录"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "审计操作信息"
                }
            ]
        }
    ]
}
