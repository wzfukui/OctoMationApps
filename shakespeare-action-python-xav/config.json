{
    "name": "xav",
    "description": "离线模拟防病毒与 EDR 轻量处置能力，支持扫描、隔离文件和清除威胁",
    "app_version": "1.0.0",
    "jar": "xav.py",
    "readme": "resources/readme.md",
    "logo": "resources/xav_logo.svg",
    "category": "安全产品",
    "product_name": "XAV 防病毒软件",
    "app_supplier": "雾帜智能",
    "logic_language": "PYTHON",
    "min_shakespeare_version": "1.0",
    "logic_language_version": "3",
    "has_test": true,
    "test_action": "health_check",
    "resources": "",
    "configuration": {
        "database_path": {
            "data_type": "string",
            "description": "SQLite 模拟状态库路径",
            "default_value": "/tmp/xav.db",
            "required": false,
            "order": 0
        },
        "scenario_profile": {
            "data_type": "string",
            "description": "模拟场景名称",
            "default_value": "default",
            "required": false,
            "order": 1
        },
        "scenario_seed": {
            "data_type": "string",
            "description": "模拟数据种子，可用于固定演示场景",
            "default_value": "x-series-default",
            "required": false,
            "order": 2
        },
        "delay_min_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最小模拟延迟秒数",
            "default_value": 1,
            "required": false,
            "order": 3
        },
        "delay_max_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最大模拟延迟秒数",
            "default_value": 3,
            "required": false,
            "order": 4
        }
    },
    "actions": [
        {
            "order": 0,
            "action": "health_check",
            "class_name": "health_check",
            "description": "健康检查",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/health_check.art",
            "safe_mode": false,
            "is_test": true,
            "classify": "query",
            "parameters": {},
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.msg",
                    "data_type": "string",
                    "description": "健康检查信息"
                },
                {
                    "data_path": "action_result.data.system_info",
                    "data_type": "jsonobject",
                    "description": "系统信息"
                }
            ]
        },
        {
            "order": 1,
            "action": "query_endpoint",
            "class_name": "query_endpoint",
            "description": "查询终端防护状态",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_endpoint.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "ip": {
                    "data_type": "string",
                    "description": "终端 IP",
                    "required": true,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 2,
            "action": "query_threat_events",
            "class_name": "query_threat_events",
            "description": "查询病毒威胁事件",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_threat_events.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "severity": {
                    "data_type": "string",
                    "description": "威胁等级",
                    "required": false,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 3,
            "action": "start_scan",
            "class_name": "start_scan",
            "description": "发起终端扫描任务",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/start_scan.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "ip": {
                    "data_type": "string",
                    "description": "终端 IP",
                    "required": true,
                    "order": 0
                },
                "scan_type": {
                    "data_type": "string",
                    "description": "扫描类型",
                    "required": false,
                    "order": 1,
                    "default_value": "quick"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 4,
            "action": "quarantine_file",
            "class_name": "quarantine_file",
            "description": "隔离恶意文件",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/quarantine_file.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "file_hash": {
                    "data_type": "string",
                    "description": "文件 Hash",
                    "required": true,
                    "order": 0
                },
                "reason": {
                    "data_type": "string",
                    "description": "隔离原因",
                    "required": false,
                    "order": 1,
                    "default_value": "命中病毒库"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 5,
            "action": "remove_threat",
            "class_name": "remove_threat",
            "description": "清除威胁",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/remove_threat.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "threat_id": {
                    "data_type": "string",
                    "description": "威胁 ID",
                    "required": true,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 6,
            "action": "query_operation_history",
            "class_name": "query_operation_history",
            "description": "查询模拟操作历史",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_operation_history.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "target": {
                    "data_type": "string",
                    "description": "目标对象，可填写 IP、主机名、用户、工单号等",
                    "required": false,
                    "order": 0
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回结果数量限制",
                    "required": false,
                    "order": 1,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        }
    ]
}
