{
    "name": "xticket",
    "description": "离线模拟工单系统，支持创建、分派、评论、流转和历史查询",
    "app_version": "1.0.0",
    "jar": "xticket.py",
    "readme": "resources/readme.md",
    "logo": "resources/xticket_logo.svg",
    "category": "IT系统",
    "product_name": "XTicket 工单系统",
    "app_supplier": "雾帜智能",
    "logic_language": "PYTHON",
    "min_shakespeare_version": "1.0",
    "logic_language_version": "3",
    "has_test": true,
    "test_action": "health_check",
    "resources": "",
    "configuration": {
        "database_path": {
            "data_type": "string",
            "description": "SQLite 模拟状态库路径",
            "default_value": "/tmp/xticket.db",
            "required": false,
            "order": 0
        },
        "scenario_profile": {
            "data_type": "string",
            "description": "模拟场景名称",
            "default_value": "default",
            "required": false,
            "order": 1
        },
        "scenario_seed": {
            "data_type": "string",
            "description": "模拟数据种子，可用于固定演示场景",
            "default_value": "x-series-default",
            "required": false,
            "order": 2
        },
        "delay_min_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最小模拟延迟秒数",
            "default_value": 1,
            "required": false,
            "order": 3
        },
        "delay_max_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最大模拟延迟秒数",
            "default_value": 3,
            "required": false,
            "order": 4
        }
    },
    "actions": [
        {
            "order": 0,
            "action": "health_check",
            "class_name": "health_check",
            "description": "健康检查",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/health_check.art",
            "safe_mode": false,
            "is_test": true,
            "classify": "query",
            "parameters": {},
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.msg",
                    "data_type": "string",
                    "description": "健康检查信息"
                },
                {
                    "data_path": "action_result.data.system_info",
                    "data_type": "jsonobject",
                    "description": "系统信息"
                }
            ]
        },
        {
            "order": 1,
            "action": "create_ticket",
            "class_name": "create_ticket",
            "description": "创建工单",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/create_ticket.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "title": {
                    "data_type": "string",
                    "description": "工单标题",
                    "required": true,
                    "order": 0
                },
                "severity": {
                    "data_type": "string",
                    "description": "严重等级",
                    "required": false,
                    "order": 1,
                    "default_value": "medium"
                },
                "description": {
                    "data_type": "string",
                    "description": "工单描述",
                    "required": false,
                    "order": 2,
                    "default_value": ""
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 2,
            "action": "query_ticket",
            "class_name": "query_ticket",
            "description": "查询工单",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_ticket.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "ticket_id": {
                    "data_type": "string",
                    "description": "工单 ID",
                    "required": true,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 3,
            "action": "update_ticket_status",
            "class_name": "update_ticket_status",
            "description": "更新工单状态",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/update_ticket_status.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "ticket_id": {
                    "data_type": "string",
                    "description": "工单 ID",
                    "required": true,
                    "order": 0
                },
                "status": {
                    "data_type": "string",
                    "description": "目标状态",
                    "required": false,
                    "order": 1,
                    "default_value": "closed"
                },
                "reason": {
                    "data_type": "string",
                    "description": "处理说明",
                    "required": false,
                    "order": 2,
                    "default_value": "处置完成"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 4,
            "action": "add_ticket_comment",
            "class_name": "add_ticket_comment",
            "description": "追加工单评论",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/add_ticket_comment.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "ticket_id": {
                    "data_type": "string",
                    "description": "工单 ID",
                    "required": true,
                    "order": 0
                },
                "comment": {
                    "data_type": "string",
                    "description": "评论内容",
                    "required": true,
                    "order": 1
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 5,
            "action": "assign_ticket",
            "class_name": "assign_ticket",
            "description": "分派工单",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/assign_ticket.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "ticket_id": {
                    "data_type": "string",
                    "description": "工单 ID",
                    "required": true,
                    "order": 0
                },
                "assignee": {
                    "data_type": "string",
                    "description": "处理人",
                    "required": true,
                    "order": 1
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 6,
            "action": "query_ticket_history",
            "class_name": "query_ticket_history",
            "description": "查询工单历史",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_ticket_history.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "ticket_id": {
                    "data_type": "string",
                    "description": "工单 ID",
                    "required": false,
                    "order": 0
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回数量",
                    "required": false,
                    "order": 1,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.history_records",
                    "data_type": "jsonarray",
                    "description": "操作历史"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                }
            ]
        }
    ]
}
