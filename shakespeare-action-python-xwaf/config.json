{
    "name": "xwaf",
    "description": "离线模拟 WAF 攻击检测、站点防护、IP 封禁和 URL 规则能力",
    "app_version": "1.0.0",
    "jar": "xwaf.py",
    "readme": "resources/readme.md",
    "logo": "resources/xwaf_logo.svg",
    "category": "安全产品",
    "product_name": "XWAF Web应用防火墙",
    "app_supplier": "雾帜智能",
    "logic_language": "PYTHON",
    "min_shakespeare_version": "1.0",
    "logic_language_version": "3",
    "has_test": true,
    "test_action": "health_check",
    "resources": "",
    "configuration": {
        "database_path": {
            "data_type": "string",
            "description": "SQLite 模拟状态库路径",
            "default_value": "/tmp/xwaf.db",
            "required": false,
            "order": 0
        },
        "scenario_profile": {
            "data_type": "string",
            "description": "模拟场景名称",
            "default_value": "default",
            "required": false,
            "order": 1
        },
        "scenario_seed": {
            "data_type": "string",
            "description": "模拟数据种子，可用于固定演示场景",
            "default_value": "x-series-default",
            "required": false,
            "order": 2
        },
        "delay_min_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最小模拟延迟秒数",
            "default_value": 1,
            "required": false,
            "order": 3
        },
        "delay_max_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最大模拟延迟秒数",
            "default_value": 3,
            "required": false,
            "order": 4
        }
    },
    "actions": [
        {
            "order": 0,
            "action": "health_check",
            "class_name": "health_check",
            "description": "健康检查",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/health_check.art",
            "safe_mode": false,
            "is_test": true,
            "classify": "query",
            "parameters": {},
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.msg",
                    "data_type": "string",
                    "description": "健康检查信息"
                },
                {
                    "data_path": "action_result.data.system_info",
                    "data_type": "jsonobject",
                    "description": "系统信息"
                }
            ]
        },
        {
            "order": 1,
            "action": "query_attack_events",
            "class_name": "query_attack_events",
            "description": "查询 Web 攻击事件",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_attack_events.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "source_ip": {
                    "data_type": "string",
                    "description": "攻击源 IP",
                    "required": false,
                    "order": 0
                },
                "severity": {
                    "data_type": "string",
                    "description": "攻击等级",
                    "required": false,
                    "order": 1
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 2,
            "action": "query_protected_sites",
            "class_name": "query_protected_sites",
            "description": "查询受保护站点",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_protected_sites.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "site": {
                    "data_type": "string",
                    "description": "站点域名",
                    "required": false,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 3,
            "action": "block_ip",
            "class_name": "block_ip",
            "description": "在 WAF 中封禁源 IP",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/block_ip.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "ip": {
                    "data_type": "string",
                    "description": "源 IP",
                    "required": true,
                    "order": 0
                },
                "reason": {
                    "data_type": "string",
                    "description": "封禁原因",
                    "required": false,
                    "order": 1,
                    "default_value": "攻击源阻断"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 4,
            "action": "unblock_ip",
            "class_name": "unblock_ip",
            "description": "解除 WAF IP 封禁",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/unblock_ip.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "ip": {
                    "data_type": "string",
                    "description": "源 IP",
                    "required": true,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 5,
            "action": "add_url_rule",
            "class_name": "add_url_rule",
            "description": "新增 URL 防护规则",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/add_url_rule.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "url": {
                    "data_type": "string",
                    "description": "URL 路径",
                    "required": true,
                    "order": 0
                },
                "rule": {
                    "data_type": "string",
                    "description": "规则名称",
                    "required": false,
                    "order": 1,
                    "default_value": "custom-block"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 6,
            "action": "query_operation_history",
            "class_name": "query_operation_history",
            "description": "查询模拟操作历史",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_operation_history.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "target": {
                    "data_type": "string",
                    "description": "目标对象，可填写 IP、主机名、用户、工单号等",
                    "required": false,
                    "order": 0
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回结果数量限制",
                    "required": false,
                    "order": 1,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        }
    ]
}
