{
    "name": "xjumpserver",
    "description": "离线模拟堡垒机访问审计，返回员工通过堡垒机访问目标设备的方式、协议、会话和命令记录",
    "app_version": "1.0.0",
    "jar": "xjumpserver.py",
    "readme": "resources/readme.md",
    "logo": "resources/xjumpserver_logo.svg",
    "category": "安全产品",
    "product_name": "XJumpServer 堡垒机",
    "app_supplier": "雾帜智能",
    "logic_language": "PYTHON",
    "min_shakespeare_version": "1.0",
    "logic_language_version": "3",
    "has_test": true,
    "test_action": "health_check",
    "resources": "",
    "configuration": {
        "database_path": {
            "data_type": "string",
            "description": "SQLite 模拟状态库路径",
            "default_value": "/tmp/xjumpserver.db",
            "required": false,
            "order": 0
        },
        "scenario_profile": {
            "data_type": "string",
            "description": "模拟场景名称",
            "default_value": "default",
            "required": false,
            "order": 1
        },
        "scenario_seed": {
            "data_type": "string",
            "description": "模拟数据种子，可用于固定演示场景",
            "default_value": "x-series-default",
            "required": false,
            "order": 2
        },
        "delay_min_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最小模拟延迟秒数",
            "default_value": 1,
            "required": false,
            "order": 3
        },
        "delay_max_seconds": {
            "data_type": "integer",
            "description": "写入/处置动作的最大模拟延迟秒数",
            "default_value": 3,
            "required": false,
            "order": 4
        }
    },
    "actions": [
        {
            "order": 0,
            "action": "health_check",
            "class_name": "health_check",
            "description": "健康检查",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/health_check.art",
            "safe_mode": false,
            "is_test": true,
            "classify": "query",
            "parameters": {},
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.msg",
                    "data_type": "string",
                    "description": "健康检查信息"
                },
                {
                    "data_path": "action_result.data.system_info",
                    "data_type": "jsonobject",
                    "description": "系统信息"
                }
            ]
        },
        {
            "order": 1,
            "action": "query_login_records",
            "class_name": "query_login_records",
            "description": "查询堡垒机登录记录",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_login_records.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "员工账号",
                    "required": false,
                    "order": 0
                },
                "target_ip": {
                    "data_type": "string",
                    "description": "目标设备 IP",
                    "required": false,
                    "order": 1
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回数量",
                    "required": false,
                    "order": 2,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 2,
            "action": "query_target_access",
            "class_name": "query_target_access",
            "description": "查询员工访问目标设备的方式",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_target_access.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "员工账号",
                    "required": false,
                    "order": 0
                },
                "target_ip": {
                    "data_type": "string",
                    "description": "目标设备 IP",
                    "required": false,
                    "order": 1
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 3,
            "action": "query_online_sessions",
            "class_name": "query_online_sessions",
            "description": "查询当前在线堡垒机会话",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_online_sessions.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "username": {
                    "data_type": "string",
                    "description": "员工账号",
                    "required": false,
                    "order": 0
                },
                "status": {
                    "data_type": "string",
                    "description": "会话状态",
                    "required": false,
                    "order": 1,
                    "default_value": "online"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 4,
            "action": "query_command_audit",
            "class_name": "query_command_audit",
            "description": "查询堡垒机命令审计",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_command_audit.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "session_id": {
                    "data_type": "string",
                    "description": "会话 ID",
                    "required": true,
                    "order": 0
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        },
        {
            "order": 5,
            "action": "terminate_session",
            "class_name": "terminate_session",
            "description": "终止堡垒机会话",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/terminate_session.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "write",
            "parameters": {
                "session_id": {
                    "data_type": "string",
                    "description": "会话 ID",
                    "required": true,
                    "order": 0
                },
                "reason": {
                    "data_type": "string",
                    "description": "终止原因",
                    "required": false,
                    "order": 1,
                    "default_value": "安全处置"
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.operation",
                    "data_type": "jsonobject",
                    "description": "模拟操作信息"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "受影响记录"
                }
            ]
        },
        {
            "order": 6,
            "action": "query_operation_history",
            "class_name": "query_operation_history",
            "description": "查询模拟操作历史",
            "result_display_tmpt_type": "js",
            "result_display_tmpt": "shakespeare-action-template/query_operation_history.art",
            "safe_mode": false,
            "is_test": false,
            "classify": "query",
            "parameters": {
                "target": {
                    "data_type": "string",
                    "description": "目标对象，可填写 IP、主机名、用户、工单号等",
                    "required": false,
                    "order": 0
                },
                "limit": {
                    "data_type": "integer",
                    "description": "返回结果数量限制",
                    "required": false,
                    "order": 1,
                    "default_value": 50
                }
            },
            "output": [
                {
                    "data_path": "action_result.code",
                    "data_type": "integer",
                    "description": "状态码"
                },
                {
                    "data_path": "action_result.data.result",
                    "data_type": "string",
                    "description": "动作结果"
                },
                {
                    "data_path": "action_result.data.records",
                    "data_type": "jsonarray",
                    "description": "查询结果"
                },
                {
                    "data_path": "action_result.data.total_count",
                    "data_type": "integer",
                    "description": "记录数量"
                },
                {
                    "data_path": "action_result.data.statistics",
                    "data_type": "jsonobject",
                    "description": "统计信息"
                }
            ]
        }
    ]
}
