<div class="ant-table ant-table-default ant-table-bordered">
    <div class="ant-table-content">
        <div class="ant-table-body">
            <table>
                <thead class="ant-table-thead">
                <tr>
                    <th><span class="ant-table-header-column"><div><span class="ant-table-column-title">描述</span></div></span></th>
                    <th><span class="ant-table-header-column"><div><span class="ant-table-column-title">值</span></div></span></th>
                </tr>
                </thead>
                <tbody class="ant-table-tbody">
                {{each action_results as action_result}}
                <tr class="ant-table-row"><td>状态码</td><td>{{action_result.summary.statusCode}}</td></tr>
                <tr class="ant-table-row"><td>执行结果</td><td>{{action_result.summary.msg}}</td></tr>
                <tr class="ant-table-row"><td>数据</td><td>{{action_result.data}}</td></tr>
                {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>
